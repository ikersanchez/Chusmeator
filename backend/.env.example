# Database Configuration
DATABASE_URL=postgresql://postgres:YOUR_STRONG_PASSWORD@db:5432/chusmeator

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=https://your-domain.com

# Security — CHANGE THESE BEFORE DEPLOYING
SECRET_KEY=generate-with-python-c-import-secrets-print-secrets.token_urlsafe-64
ADMIN_KEY=generate-with-python-c-import-secrets-print-secrets.token_urlsafe-32

# Session cookie
SESSION_COOKIE_NAME=chusmeator_session

# HTTPS (set to true in production)
HTTPS_ONLY=true

# Debug mode (set to false in production — disables Swagger docs, X-User-Id header)
DEBUG=false

# LocationIQ API (address search)
LOCATIONIQ_URL=https://us1.locationiq.com/v1/search
LOCATIONIQ_API_KEY=your_locationiq_api_key_here

# DeepSeek API (content moderation)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Postgres credentials (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_STRONG_PASSWORD
POSTGRES_DB=chusmeator

# Abuse prevention limits
MAX_PINS_PER_DAY=10
MAX_AREAS_PER_DAY=10
MAX_COMMENTS_PER_DAY=10
